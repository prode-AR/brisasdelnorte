<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Brisas del Norte · Departamento en Jujuy</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --ink:    #0f0f0f;
  --slate:  #1c1c1e;
  --mid:    #3a3a3c;
  --soft:   #8e8e93;
  --line:   #e5e5ea;
  --bg:     #f9f9fb;
  --white:  #ffffff;
  --gold:   #b8965a;
  --gold2:  #d4b07a;
  --cream:  #f5f0e8;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--ink);overflow-x:hidden}

/* ══ NAV ══ */
nav{
  position:fixed;top:0;left:0;right:0;z-index:300;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 2.5rem;height:64px;
  background:rgba(15,15,15,0.0);
  transition:background 0.4s,backdrop-filter 0.4s,box-shadow 0.4s;
}
nav.scrolled{
  background:rgba(15,15,15,0.95);
  backdrop-filter:blur(18px);
  box-shadow:0 1px 0 rgba(255,255,255,0.06);
}
.nav-logo{
  font-family:'DM Serif Display',serif;font-size:1.15rem;
  color:#fff;text-decoration:none;letter-spacing:0.02em;
  flex-shrink:0;
}
.nav-logo span{color:var(--gold);font-style:italic}

/* Desktop links */
.nav-desktop{display:flex;gap:0;list-style:none}
.nav-desktop a{
  display:block;padding:0 1.1rem;height:64px;line-height:64px;
  font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;font-weight:500;
  color:rgba(255,255,255,0.72);text-decoration:none;
  position:relative;transition:color 0.2s;
}
.nav-desktop a::after{
  content:'';position:absolute;bottom:0;left:1.1rem;right:1.1rem;height:2px;
  background:var(--gold);transform:scaleX(0);transition:transform 0.25s;
}
.nav-desktop a:hover{color:#fff}
.nav-desktop a:hover::after{transform:scaleX(1)}
.nav-desktop a.active{color:#fff}
.nav-desktop a.active::after{transform:scaleX(1)}

/* Hamburger */
.hamburger{
  display:none;flex-direction:column;justify-content:center;gap:5px;
  width:40px;height:40px;cursor:pointer;background:none;border:none;padding:6px;z-index:400;
}
.hamburger span{
  display:block;width:100%;height:1.5px;background:#fff;border-radius:2px;
  transition:transform 0.3s,opacity 0.3s;
}
.hamburger.open span:nth-child(1){transform:translateY(6.5px) rotate(45deg)}
.hamburger.open span:nth-child(2){opacity:0}
.hamburger.open span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg)}

/* Mobile drawer */
.mobile-drawer{
  position:fixed;inset:0;z-index:250;
  background:var(--slate);
  display:flex;flex-direction:column;justify-content:center;align-items:flex-start;
  padding:3rem 2.5rem;
  opacity:0;pointer-events:none;transform:translateX(100%);
  transition:opacity 0.35s,transform 0.35s;
}
.mobile-drawer.open{opacity:1;pointer-events:all;transform:translateX(0)}
.mobile-drawer a{
  font-family:'DM Serif Display',serif;font-size:2.8rem;font-style:italic;
  color:rgba(255,255,255,0.85);text-decoration:none;
  padding:0.6rem 0;border-bottom:1px solid rgba(255,255,255,0.06);width:100%;
  transition:color 0.2s,padding-left 0.2s;
}
.mobile-drawer a:hover{color:var(--gold);padding-left:0.5rem}
.drawer-tag{
  font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;
  color:var(--gold);margin-bottom:2.5rem;
}

/* ══ HERO ══ */
#inicio{
  height:100vh;position:relative;
  display:flex;align-items:center;overflow:hidden;
}
.hero-bg{
  position:absolute;inset:0;
  background:center/cover no-repeat;
  transform:scale(1.05);
  transition:transform 8s ease-out;
  filter:brightness(0.45);
}
#inicio.loaded .hero-bg{transform:scale(1)}
.hero-content{
  position:relative;z-index:2;
  max-width:760px;padding:0 2.5rem;
  opacity:0;transform:translateY(24px);
  transition:opacity 0.9s 0.2s,transform 0.9s 0.2s;
}
#inicio.loaded .hero-content{opacity:1;transform:translateY(0)}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:0.7rem;
  font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;
  color:var(--gold2);margin-bottom:1.4rem;
}
.hero-eyebrow::before{content:'';width:2rem;height:1px;background:var(--gold);display:block}
h1{
  font-family:'DM Serif Display',serif;
  font-size:clamp(3rem,8vw,6rem);
  font-weight:400;line-height:1.02;color:#fff;
  margin-bottom:1.4rem;
}
h1 em{font-style:italic;color:var(--gold2)}
.hero-desc{
  font-size:1rem;line-height:1.8;color:rgba(255,255,255,0.65);
  max-width:460px;margin-bottom:2.8rem;
}
.hero-actions{display:flex;gap:1rem;flex-wrap:wrap}

/* ══ BUTTONS ══ */
.btn{
  display:inline-flex;align-items:center;gap:0.5rem;
  padding:0.82rem 1.7rem;
  font-family:'DM Sans',sans-serif;font-size:0.72rem;
  letter-spacing:0.14em;text-transform:uppercase;font-weight:500;
  text-decoration:none;cursor:pointer;border:none;
  transition:all 0.22s;
}
.btn-outline{background:transparent;border:1px solid rgba(255,255,255,0.4);color:#fff}
.btn-outline:hover{background:#fff;color:var(--ink);border-color:#fff}
.btn-gold{background:var(--gold);color:#fff;border:1px solid var(--gold)}
.btn-gold:hover{background:var(--gold2);border-color:var(--gold2)}
.btn-dark{background:var(--ink);color:#fff;border:1px solid var(--ink)}
.btn-dark:hover{background:var(--slate);border-color:var(--slate)}
.btn-wapp{background:#25D366;color:#fff;border:1px solid #25D366}
.btn-wapp:hover{background:#1fba5a;border-color:#1fba5a}
.btn-book{background:#003580;color:#fff;border:1px solid #003580}
.btn-book:hover{background:#00276b;border-color:#00276b}

/* ══ SECTIONS ══ */
section{padding:6rem 2.5rem;scroll-margin-top:64px}
.eyebrow{
  font-size:0.63rem;letter-spacing:0.3em;text-transform:uppercase;
  color:var(--gold);margin-bottom:0.8rem;
  display:flex;align-items:center;gap:0.6rem;
}
.eyebrow::before{content:'';width:1.5rem;height:1px;background:var(--gold);display:block}
h2{
  font-family:'DM Serif Display',serif;
  font-size:clamp(2rem,4vw,2.8rem);font-weight:400;
  line-height:1.12;color:var(--ink);margin-bottom:1.5rem;
}
h2 em{font-style:italic;color:var(--mid)}

/* ══ INICIO (hero handled above) ══ */

/* ══ SERVICIOS ══ */
#servicios{background:var(--white)}
.servicios-layout{
  display:grid;grid-template-columns:1fr;gap:0;align-items:center;
  margin-top:0;
  max-width:860px;
}
.servicios-img{
  position:relative;
}
.servicios-img img{
  width:100%;aspect-ratio:4/3;object-fit:cover;display:block;
}
.servicios-img::after{
  content:'';position:absolute;top:1.5rem;left:1.5rem;right:-1.5rem;bottom:-1.5rem;
  border:1px solid var(--gold);z-index:-1;
}
.servicios-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:2rem;
}
.servicio-item{
  display:flex;align-items:flex-start;gap:0.9rem;
  padding:1.2rem;background:var(--bg);
  border-left:2px solid var(--gold);
  transition:background 0.2s;
}
.servicio-item:hover{background:var(--cream)}
.servicio-icon{font-size:1.4rem;flex-shrink:0;margin-top:1px}
.servicio-title{font-size:0.8rem;font-weight:600;letter-spacing:0.04em;margin-bottom:0.2rem}
.servicio-desc{font-size:0.78rem;color:var(--soft);line-height:1.5}

/* ══ HABITACIONES ══ */
#habitaciones{background:var(--bg)}
.hab-intro{max-width:560px;margin-bottom:3rem}
.hab-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  grid-template-rows:280px 280px;
  gap:6px;
}
.hab-item{
  overflow:hidden;position:relative;background:var(--line);
  cursor:zoom-in;
  transition:transform 0.4s cubic-bezier(.25,.8,.25,1), box-shadow 0.4s, z-index 0s;
  z-index:1;
}
.hab-item.big{grid-column:span 2;grid-row:span 2}
.hab-item:hover{
  transform:scale(1.04);
  box-shadow:0 20px 60px rgba(0,0,0,0.35);
  z-index:10;
}
.hab-item img{
  width:100%;height:100%;object-fit:cover;display:block;
  transition:transform 0.5s ease;
}
.hab-item:hover img{transform:scale(1.0)}
.hab-caption{
  position:absolute;bottom:0;left:0;right:0;
  padding:2rem 1.2rem 1rem;
  background:linear-gradient(transparent,rgba(15,15,15,0.82));
  color:#fff;font-size:0.72rem;letter-spacing:0.16em;text-transform:uppercase;
  opacity:0;transition:opacity 0.3s;
}
.hab-item:hover .hab-caption{opacity:1}

/* ── LIGHTBOX ── */
.lightbox{
  position:fixed;inset:0;z-index:9999;
  background:rgba(0,0,0,0);
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;
  transition:opacity 0.35s, background 0.35s;
}
.lightbox.open{
  opacity:1;pointer-events:all;
  background:rgba(0,0,0,0.92);
}
.lightbox-inner{
  position:relative;
  max-width:92vw;max-height:88vh;
  transform:scale(0.88);
  transition:transform 0.35s cubic-bezier(.25,.8,.25,1);
}
.lightbox.open .lightbox-inner{transform:scale(1)}
.lightbox-inner img{
  display:block;
  max-width:92vw;max-height:88vh;
  width:auto;height:auto;
  object-fit:contain;
  box-shadow:0 30px 80px rgba(0,0,0,0.6);
}
.lightbox-caption{
  position:absolute;bottom:-2.2rem;left:0;right:0;
  text-align:center;font-size:0.7rem;letter-spacing:0.2em;
  text-transform:uppercase;color:rgba(255,255,255,0.45);
}
.lightbox-close{
  position:absolute;top:-2.8rem;right:0;
  background:none;border:none;color:#fff;font-size:1.5rem;
  cursor:pointer;opacity:0.6;transition:opacity 0.2s;padding:0.3rem;
  line-height:1;
}
.lightbox-close:hover{opacity:1}
.lightbox-prev,.lightbox-next{
  position:fixed;top:50%;transform:translateY(-50%);
  background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);
  color:#fff;font-size:1.2rem;
  width:48px;height:48px;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:background 0.2s;
  z-index:10000;
}
.lightbox-prev{left:1.2rem}
.lightbox-next{right:1.2rem}
.lightbox-prev:hover,.lightbox-next:hover{background:rgba(255,255,255,0.18)}

/* ══ TARIFAS ══ */
#tarifas{background:var(--ink);text-align:center;position:relative;overflow:hidden}
#tarifas::before{
  content:'$';
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  font-family:'DM Serif Display',serif;
  font-size:clamp(14rem,35vw,28rem);
  color:rgba(255,255,255,0.025);line-height:1;pointer-events:none;
}
#tarifas h2{color:#fff}
#tarifas h2 em{color:var(--gold2)}
#tarifas .eyebrow{justify-content:center;color:var(--gold2)}
#tarifas .eyebrow::before{background:var(--gold)}
.tarifa-desc{
  font-size:0.95rem;color:rgba(255,255,255,0.5);
  max-width:440px;margin:0 auto 3.5rem;line-height:1.8;
}
.tarifas-cards{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:1.5rem;max-width:860px;margin:0 auto 3rem;
  position:relative;z-index:1;
}
.tarifa-card{
  padding:2.5rem 2rem;
  border:1px solid rgba(255,255,255,0.08);
  background:rgba(255,255,255,0.04);
  transition:border-color 0.3s,background 0.3s,transform 0.3s;
  text-align:center;
}
.tarifa-card.featured{
  border-color:var(--gold);
  background:rgba(184,150,90,0.1);
}
.tarifa-card:hover{transform:translateY(-4px);border-color:var(--gold)}
.tarifa-tipo{
  font-size:0.68rem;letter-spacing:0.22em;text-transform:uppercase;
  color:rgba(255,255,255,0.4);margin-bottom:1.2rem;
}
.tarifa-precio{
  font-family:'DM Serif Display',serif;font-size:2.6rem;font-weight:400;
  color:#fff;line-height:1;margin-bottom:0.4rem;
}
.tarifa-precio span{font-size:1.2rem;color:var(--gold2)}
.tarifa-unit{font-size:0.72rem;color:var(--soft);letter-spacing:0.08em}
.tarifa-items{
  margin-top:1.5rem;padding-top:1.5rem;
  border-top:1px solid rgba(255,255,255,0.07);
  list-style:none;display:flex;flex-direction:column;gap:0.5rem;
}
.tarifa-items li{
  font-size:0.78rem;color:rgba(255,255,255,0.55);
  display:flex;align-items:center;justify-content:center;gap:0.4rem;
}
.tarifa-items li::before{content:'✓';color:var(--gold);font-size:0.7rem}
.tarifa-note{
  font-size:0.75rem;color:rgba(255,255,255,0.3);
  position:relative;z-index:1;margin-top:1rem;
}

/* ══ CONTACTO ══ */
#contacto{background:var(--white)}
.contacto-layout{
  display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start;
}
.contacto-left p{
  font-size:0.96rem;line-height:1.85;color:var(--mid);margin-bottom:2rem;
}
.contacto-channels{display:flex;flex-direction:column;gap:1rem;margin-bottom:2.5rem}
.channel-btn{
  display:flex;align-items:center;gap:1rem;
  padding:1.1rem 1.4rem;text-decoration:none;
  border:1px solid var(--line);
  transition:border-color 0.2s,background 0.2s;
}
.channel-btn:hover{border-color:var(--ink);background:var(--bg)}
.channel-icon{font-size:1.4rem;flex-shrink:0}
.channel-label{font-size:0.68rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--soft);margin-bottom:0.2rem}
.channel-value{font-size:0.9rem;font-weight:500;color:var(--ink)}
.contacto-right{background:var(--bg);padding:2.5rem}
.info-block{margin-bottom:2rem}
.info-block:last-child{margin-bottom:0}
.info-label{
  font-size:0.65rem;letter-spacing:0.22em;text-transform:uppercase;
  color:var(--soft);margin-bottom:0.5rem;
}
.info-value{
  font-family:'DM Serif Display',serif;font-size:1.2rem;font-style:italic;
  color:var(--ink);line-height:1.4;
}
.map-link{
  display:inline-flex;align-items:center;gap:0.6rem;
  font-size:0.82rem;letter-spacing:0.06em;text-transform:uppercase;font-weight:500;
  color:var(--white);text-decoration:none;margin-top:1rem;
  background:var(--ink);border:1px solid var(--gold);
  padding:0.7rem 1.2rem;
  transition:background 0.22s,color 0.22s;
}
.map-link:hover{background:var(--gold);color:var(--white)}

/* ══ FOOTER ══ */
footer{
  background:var(--ink);padding:2rem 2.5rem;
  display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;
}
.footer-logo{
  font-family:'DM Serif Display',serif;font-style:italic;
  font-size:1rem;color:rgba(255,255,255,0.35);
}
footer p{font-size:0.68rem;color:rgba(255,255,255,0.2);letter-spacing:0.05em}

/* ══ DIVIDER ══ */
.section-divider{height:1px;background:var(--line);margin:0 2.5rem}

/* ══ REVEAL ══ */
.reveal{opacity:0;transform:translateY(22px);transition:opacity 0.75s,transform 0.75s}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ══ RESPONSIVE ══ */
@media(max-width:860px){
  .nav-desktop{display:none}
  .hamburger{display:flex}
  section{padding:4rem 1.4rem;scroll-margin-top:64px}
  .servicios-layout,.contacto-layout{grid-template-columns:1fr;gap:2.5rem}
  .servicios-img::after{display:none}
  .hab-grid{
    grid-template-columns:1fr 1fr;
    grid-template-rows:200px 200px 200px;
  }
  .hab-item.big{grid-column:span 2;grid-row:span 1}
  h1{font-size:3rem}
  .hero-content{padding:0 1.4rem}
  .tarifas-cards{grid-template-columns:1fr}
}
@media(max-width:500px){
  .servicios-grid{grid-template-columns:1fr}
  .hab-grid{grid-template-columns:1fr;grid-template-rows:auto}
  .hab-item.big{grid-column:span 1}
  .hab-item{height:220px}
}

/* ══ RESERVAS ══ */
#reservas{background:var(--bg);scroll-margin-top:64px}
.reservas-layout{
  display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start;
  margin-top:3rem;
}
.reservas-form-card{
  background:var(--white);
  border:1px solid var(--line);
  padding:2.5rem;
}
.reservas-form-card h3{
  font-family:'DM Serif Display',serif;font-size:1.5rem;font-weight:400;
  color:var(--ink);margin-bottom:0.4rem;
}
.form-subtitle{font-size:0.82rem;color:var(--soft);margin-bottom:2rem;line-height:1.5}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem}
.form-group{display:flex;flex-direction:column;gap:0.4rem}
.form-group.full{grid-column:span 2}
.form-label{
  font-size:0.65rem;letter-spacing:0.18em;text-transform:uppercase;
  color:var(--soft);font-weight:500;
}
.form-input{
  padding:0.75rem 1rem;
  border:1px solid var(--line);background:var(--bg);
  font-family:'DM Sans',sans-serif;font-size:0.9rem;color:var(--ink);
  appearance:none;outline:none;
  transition:border-color 0.2s,background 0.2s;
  cursor:pointer;
}
.form-input:focus{border-color:var(--gold);background:var(--white)}
.form-input:hover{border-color:var(--gold2)}
.guests-row{display:flex;align-items:center;gap:0;margin-top:0.4rem}
.guests-btn{
  width:36px;height:36px;background:var(--bg);border:1px solid var(--line);
  font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;
  color:var(--ink);transition:background 0.2s,border-color 0.2s;flex-shrink:0;
  user-select:none;
}
.guests-btn:hover{background:var(--cream);border-color:var(--gold)}
.guests-count{
  width:48px;height:36px;border-top:1px solid var(--line);border-bottom:1px solid var(--line);
  border-left:none;border-right:none;
  display:flex;align-items:center;justify-content:center;
  font-size:0.95rem;font-weight:500;color:var(--ink);
  background:var(--white);
}
.price-preview{
  margin:1.5rem 0;padding:1.2rem;
  background:var(--cream);
  border-left:3px solid var(--gold);
  display:none;
}
.price-preview.visible{display:block}
.price-row{
  display:flex;justify-content:space-between;align-items:center;
  font-size:0.85rem;color:var(--mid);padding:0.25rem 0;
}
.price-row.total{
  font-weight:600;font-size:1rem;color:var(--ink);
  border-top:1px solid var(--mist);margin-top:0.5rem;padding-top:0.75rem;
}
.price-row.total span:last-child{color:var(--gold);font-family:'DM Serif Display',serif;font-size:1.2rem}
.btn-reservar{
  width:100%;padding:1rem;
  background:var(--ink);color:#fff;
  font-family:'DM Sans',sans-serif;font-size:0.78rem;
  letter-spacing:0.18em;text-transform:uppercase;font-weight:500;
  border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:0.6rem;
  transition:background 0.22s;
  text-decoration:none;
  margin-top:1rem;
}
.btn-reservar:hover{background:var(--slate)}
.btn-reservar:disabled{opacity:0.4;cursor:not-allowed}
.reserva-nota{
  font-size:0.72rem;color:var(--soft);text-align:center;
  margin-top:0.8rem;line-height:1.5;
}
/* Info lateral */
.reservas-info{display:flex;flex-direction:column;gap:1.5rem}
.info-card{
  padding:1.5rem;
  border:1px solid var(--line);background:var(--white);
}
.info-card-icon{font-size:1.5rem;margin-bottom:0.8rem;display:block}
.info-card h4{
  font-family:'DM Serif Display',serif;font-size:1rem;font-weight:400;
  color:var(--ink);margin-bottom:0.4rem;
}
.info-card p{font-size:0.82rem;color:var(--soft);line-height:1.6}
.tarifa-inline{
  display:flex;align-items:baseline;gap:0.3rem;
  font-family:'DM Serif Display',serif;font-size:1.8rem;color:var(--ink);margin:0.5rem 0 0.2rem;
}
