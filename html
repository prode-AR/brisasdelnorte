<script>
const I = {
  hero: 'data:image/png;base64,',
  i1:   'data:image/png;base64,',
  i2:   'data:image/png;base64,',
  i3:   'data:image/png;base64,',
  i4:   'data:image/png;base64,',
  i5:   'data:image/png;base64,',
};
document.getElementById('heroBg').style.backgroundImage = `url('${I.hero}')`;
document.getElementById('imgHab1').src  = I.i2;
document.getElementById('imgHab2').src  = I.i1;
document.getElementById('imgHab3').src  = I.i3;
document.getElementById('imgHab4').src  = I.i4;
document.getElementById('imgHab5').src  = I.i5;

// Nav scroll
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 60));

// Active nav link
const sections = document.querySelectorAll('section[id]');
const links = document.querySelectorAll('.nav-desktop a');
const onScroll = () => {
  let current = '';
  sections.forEach(s => { if (window.scrollY >= s.offsetTop - 80) current = s.id; });
  links.forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#' + current);
  });
};
window.addEventListener('scroll', onScroll);

// Hero load
window.addEventListener('load', () => document.getElementById('inicio').classList.add('loaded'));

// Drawer
function toggleDrawer() {
  document.getElementById('drawer').classList.toggle('open');
  document.getElementById('hb').classList.toggle('open');
  document.body.style.overflow = document.getElementById('drawer').classList.contains('open') ? 'hidden' : '';
}
function closeDrawer() {
  document.getElementById('drawer').classList.remove('open');
  document.getElementById('hb').classList.remove('open');
  document.body.style.overflow = '';
}

// Reveal
const reveals = document.querySelectorAll('.reveal');
const obs = new IntersectionObserver(entries => {
  entries.forEach((e,i) => {
    if (e.isIntersecting) {
      setTimeout(() => e.target.classList.add('visible'), i * 80);
      obs.unobserve(e.target);
    }
  });
}, {threshold: 0.1});
reveals.forEach(el => obs.observe(el));

// ══ RESERVAS LOGIC ══
const PRICE_PER_NIGHT = 60000;
let guests = 2;

function changeGuests(delta) {
  guests = Math.min(4, Math.max(1, guests + delta));
  document.getElementById('guestCount').textContent = guests;
  updatePrice();
}

function updatePrice() {
  const ci = document.getElementById('checkin').value;
  const co = document.getElementById('checkout').value;
  if (!ci || !co) { document.getElementById('pricePreview').classList.remove('visible'); return; }
  const diff = Math.round((new Date(co) - new Date(ci)) / 86400000);
  if (diff <= 0) { document.getElementById('pricePreview').classList.remove('visible'); return; }
  const total = diff * PRICE_PER_NIGHT;
  const fmt = n => '$\u00a0' + n.toLocaleString('es-AR');
  document.getElementById('nightsLabel').textContent = diff + ' noche' + (diff > 1 ? 's' : '');
  document.getElementById('priceBase').textContent = fmt(PRICE_PER_NIGHT) + ' x ' + diff;
  document.getElementById('priceTotal').textContent = fmt(total);
  document.getElementById('pricePreview').classList.add('visible');
}

document.getElementById('checkin').addEventListener('change', function() {
  // Auto-set min checkout
  if (this.value) {
    const next = new Date(this.value);
    next.setDate(next.getDate() + 1);
    const minCo = next.toISOString().split('T')[0];
    document.getElementById('checkout').min = minCo;
    if (document.getElementById('checkout').value < minCo) {
      document.getElementById('checkout').value = minCo;
    }
  }
  updatePrice();
});
document.getElementById('checkout').addEventListener('change', updatePrice);

// Set min date = today
const todayStr = new Date().toISOString().split('T')[0];
document.getElementById('checkin').min = todayStr;
document.getElementById('checkout').min = todayStr;

function openBooking() {
  const ci = document.getElementById('checkin').value;
  const co = document.getElementById('checkout').value;
  let ok = true;
  if (!ci) { document.getElementById('err-checkin').style.display='block'; ok=false; }
  else { document.getElementById('err-checkin').style.display='none'; }
  if (!co || co <= ci) { document.getElementById('err-checkout').style.display='block'; ok=false; }
  else { document.getElementById('err-checkout').style.display='none'; }
  if (!ok) return false;

  // Booking.com URL con parámetros de fecha y huéspedes
  // checkin/checkout formato YYYY-MM-DD, group_adults = cantidad huéspedes
  const url = 'https://www.booking.com/hotel/ar/brisas-del-norte.es.html'
    + '?checkin=' + ci
    + '&checkout=' + co
    + '&group_adults=' + guests
    + '&group_children=0'
    + '&no_rooms=1'
    + '&label=gog235jc-10CAEoggI46AdILFgDaAyIAQGYATO4ARfIAQzYAQPoAQH4AQGIAgGoAgG4Ar6ews4GwAIB0gIkYWEzM2EzNTktZGFmMC00MmE3LTlkOWYtMzZkOWFhODZlNjhl2AIB4AIB'
    + '&aid=397594';

  window.open(url, '_blank');
  return false;
}


// ── LIGHTBOX ──
let lbImages = [];
let lbIndex  = 0;

function buildGallery() {
  const items = document.querySelectorAll('.hab-item');
  lbImages = [];
  items.forEach((item, i) => {
    const img     = item.querySelector('img');
    const caption = item.querySelector('.hab-caption');
    if (!img) return;
    lbImages.push({ src: img.src, caption: caption ? caption.textContent : '' });
    item.addEventListener('click', () => openLightbox(i));
  });
}

function openLightbox(index) {
  lbIndex = index;
  showLightboxImg();
  document.getElementById('lightbox').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function showLightboxImg() {
  const lb  = lbImages[lbIndex];
  document.getElementById('lightboxImg').src           = lb.src;
  document.getElementById('lightboxCaption').textContent = lb.caption;
}

function closeLightbox(e) {
  if (e && e.target !== document.getElementById('lightbox') && !e.target.classList.contains('lightbox-close')) return;
  document.getElementById('lightbox').classList.remove('open');
  document.body.style.overflow = '';
}

function prevImg(e) {
  e.stopPropagation();
  lbIndex = (lbIndex - 1 + lbImages.length) % lbImages.length;
  showLightboxImg();
}

function nextImg(e) {
  e.stopPropagation();
  lbIndex = (lbIndex + 1) % lbImages.length;
  showLightboxImg();
}

// Keyboard nav
document.addEventListener('keydown', e => {
  const lb = document.getElementById('lightbox');
  if (!lb.classList.contains('open')) return;
  if (e.key === 'Escape')      closeLightbox();
  if (e.key === 'ArrowLeft')   { lbIndex = (lbIndex-1+lbImages.length)%lbImages.length; showLightboxImg(); }
  if (e.key === 'ArrowRight')  { lbIndex = (lbIndex+1)%lbImages.length; showLightboxImg(); }
});

window.addEventListener('load', buildGallery);

</script>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox" onclick="closeLightbox(event)">
  <button class="lightbox-close" onclick="closeLightbox()">✕</button>
  <button class="lightbox-prev" onclick="prevImg(event)">&#8592;</button>
  <button class="lightbox-next" onclick="nextImg(event)">&#8594;</button>
  <div class="lightbox-inner">
    <img id="lightboxImg" src="" alt="">
    <div class="lightbox-caption" id="lightboxCaption"></div>
  </div>
</div>
</body>
